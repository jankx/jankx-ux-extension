{
    "name": "jankx/jankx-ux",
    "description": "Jankx UX Extension - Professional re-implementation of UX patterns with PSR-4 and static classes.",
    "type": "jankx-extension",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Jankx\\Extensions\\JankxUX\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jankx\\Extensions\\JankxUX\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "brain/monkey": "^2.6"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test-coverage": "./vendor/bin/phpunit --coverage-html coverage-report",
        "test-watch": "./vendor/bin/phpunit --testdox --colors=always"
    }
}
